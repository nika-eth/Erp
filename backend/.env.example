# --- PostgreSQL ---
PGHOST=localhost
PGPORT=5432
PGDATABASE=erp_metalurgica
PGUSER=postgres
PGPASSWORD=postgres
PG_POOL_MAX=10

# --- Servidor ---
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# --- Sesión / Identidad ---
# Secreto para firmar el JWT de sesión (sucursal + rol + vendedor).
# No hay tabla `usuarios` en el modelo de datos provisto, por lo que el login
# real contra credenciales queda fuera de este núcleo: /api/auth/login emite
# un token a partir de sucursal + rol + nombre de vendedor seleccionados.
JWT_SECRET=cambiar-este-secreto-en-produccion
JWT_EXPIRES_IN=12h

# --- AFIP (WSFE v1) ---
# Sin AFIP_CERT_PATH/AFIP_KEY_PATH configurados, toda venta fiscal (Factura
# A/B) cae automáticamente en CONTINGENCIA: es el comportamiento esperado en
# desarrollo/CI sin certificado real, no un error.
AFIP_ENTORNO=homologacion
AFIP_CUIT=
AFIP_CERT_PATH=
AFIP_KEY_PATH=
AFIP_PUNTO_VENTA=1
AFIP_PUNTO_VENTA_INTERNO=0
AFIP_TIMEOUT_MS=4000
AFIP_WORKER_INTERVAL_MS=60000
AFIP_MAX_REINTENTOS=10
# Opcionales: por defecto apuntan a los endpoints públicos de homologación/producción de AFIP.
# AFIP_WSAA_URL=
# AFIP_WSFE_URL=
