# --- PostgreSQL ---
PGHOST=localhost
PGPORT=5432
PGDATABASE=erp_metalurgica
PGUSER=postgres
PGPASSWORD=postgres
PG_POOL_MAX=10

# --- Servidor ---
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# --- Sesión / Identidad ---
# Secreto para firmar el JWT de sesión (sucursal + rol + vendedor).
# No hay tabla `usuarios` en el modelo de datos provisto, por lo que el login
# real contra credenciales queda fuera de este núcleo: /api/auth/login emite
# un token a partir de sucursal + rol + nombre de vendedor seleccionados.
JWT_SECRET=cambiar-este-secreto-en-produccion
JWT_EXPIRES_IN=12h
